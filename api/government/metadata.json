{
  "feed_name": "Canadian Government Phishing Domains",
  "feed_description": "Comprehensive threat intelligence feed of Canadian Government phishing domains detected through advanced pattern matching and WHOXY API integration.",
  "feed_category": "government",
  "feed_sector": "government_services",
  "feed_region": "canada",
  "feed_language": "en",
  "feed_version": "2.0.0",
  "feed_license": "MIT",
  "feed_maintainer": "PhishCan Security Team",
  "feed_contact": "https://github.com/Phishcan/phishcan-data",
  
  "data_structure": {
    "format": "json",
    "encoding": "utf-8",
    "compression": "none",
    "schema_version": "1.0"
  },
  
  "fields": {
    "domain": {
      "type": "string",
      "description": "The phishing domain identified",
      "format": "domain_name",
      "example": "example-verify.com",
      "required": true
    },
    "category": {
      "type": "string",
      "description": "The threat category classification",
      "enum": ["government"],
      "example": "government",
      "required": true
    },
    "score": {
      "type": "number",
      "description": "Confidence score indicating detection reliability (3.0+ = high confidence)",
      "minimum": 3.0,
      "maximum": 15.0,
      "example": 12.0,
      "required": true
    },
    "detected_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when the domain was detected",
      "format": "date-time",
      "example": "2025-09-01T15:17:13.215966",
      "required": true
    },
    "source": {
      "type": "string",
      "description": "Detection method or source",
      "enum": ["government_detection", "comprehensive_detection"],
      "example": "government_detection",
      "required": true
    }
  },
  
  "update_frequency": {
    "automatic": "every_12_hours",
    "manual": "force_run_available",
    "last_update": "2025-09-01T21:20:05Z",
    "next_scheduled": "2025-09-02T09:20:05Z"
  },
  
  "statistics": {
    "total_domains": 0,
    "new_since_last_run": 0,
    "high_confidence_domains": 0,
    "medium_confidence_domains": 0,
    "low_confidence_domains": 0
  },
  
  "confidence_levels": {
    "high": {
      "score_range": "8.0-15.0",
      "description": "Strong indicators of phishing activity",
      "count": 0
    },
    "medium": {
      "score_range": "3.0-7.9",
      "description": "Moderate indicators, requires review",
      "count": 0
    },
    "low": {
      "score_range": "0.0-2.9",
      "description": "Weak indicators, excluded from feed",
      "count": 0
    }
  },
  
  "file_formats": {
    "json": {
      "url": "https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.json",
      "size": "0B",
      "records": 0
    },
    "csv": {
      "url": "https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.csv",
      "size": "0B",
      "records": 0
    },
    "javascript": {
      "url": "https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.js",
      "size": "0B",
      "format": "ES6_module"
    }
  },
  
  "usage_examples": {
    "javascript": "const response = await fetch('https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.json'); const domains = await response.json();",
    "python": "import requests; response = requests.get('https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.json'); domains = response.json();",
    "curl": "curl -s 'https://raw.githubusercontent.com/Phishcan/phishcan-data/main/api/government/canadian_government_phishing_domains.json' | jq '.[].domain'"
  },
  
  "data_quality": {
    "accuracy": "high",
    "false_positive_rate": "<5%",
    "coverage": "comprehensive",
    "freshness": "real_time",
    "validation": "automated"
  },
  
  "compliance": {
    "data_retention": "indefinite",
    "privacy": "no_pii",
    "sharing": "public",
    "licensing": "mit",
    "attribution": "required"
  }
}
